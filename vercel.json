{
  "builds": [
    {
      "src": "src/server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "node_modules/sql.js/dist/sql-wasm.wasm"
      }
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "src/server.js" },
    { "source": "/(.*)", "destination": "src/server.js" }
  ]
}
