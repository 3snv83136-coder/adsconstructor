# ============================================================
#  AdWords Automator - Configuration
# ============================================================

# --- Serveur ---
PORT=3000
NODE_ENV=development

# --- Base de données PostgreSQL (Supabase) ---
# Connection string du projet Supabase. Utiliser le "Connection Pooler"
# (Transaction mode, port 6543) pour un déploiement serverless (Vercel).
# Récupérable dans : Supabase > Project Settings > Database > Connection string
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# Taille max du pool de connexions (1 recommandé sur Vercel)
DB_POOL_MAX=10

# --- Vercel Cron ---
# Secret partagé protégeant les endpoints /api/cron/*.
# Définir la même valeur dans les variables d'environnement Vercel :
# Vercel envoie alors automatiquement l'en-tête Authorization sur les crons.
CRON_SECRET=

# --- Google Ads API (optionnel — mode simulation si absent) ---
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# --- Détection de fraude ---
FRAUD_MAX_CLICKS_PER_IP_PER_MINUTE=10
FRAUD_MAX_CLICKS_PER_IP_PER_HOUR=50
FRAUD_CLICK_VELOCITY_THRESHOLD_MS=200
FRAUD_SUSPICIOUS_UA_PATTERNS=bot,crawler,spider,scraper,headless
FRAUD_BLOCK_DURATION_MINUTES=60
FRAUD_AUTO_BLOCK_ENABLED=true

# --- Optimiseur ROI ---
ROI_MIN_COST_THRESHOLD=5.0
ROI_TARGET_CPA=15.0
ROI_MAX_BID_ADJUSTMENT_PCT=50
ROI_MIN_BID_ADJUSTMENT_PCT=-30
ROI_CHECK_INTERVAL_MINUTES=5
ROI_CONVERSION_WINDOW_DAYS=7

# --- Calendrier ---
CALENDAR_DEFAULT_TIMEZONE=Europe/Paris
CALENDAR_MAX_CONCURRENT_CAMPAIGNS=5

# --- Logs ---
LOG_LEVEL=info
LOG_FILE=./logs/app.log
