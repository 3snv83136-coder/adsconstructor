# ============================================================
#  AdWords Automator - Variables d'environnement
# ============================================================

# --- Base de données Postgres (Supabase) ---
# Récupère cette URL dans Supabase Dashboard :
#   Project Settings → Database → Connection Pooling
#   Mode "Transaction" (port 6543) recommandé pour serverless
POSTGRES_URL=postgresql://postgres.<project_ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# --- Serveur ---
PORT=3000
NODE_ENV=development

# --- Google Ads API (optionnel — passe en mode simulation si absent) ---
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# --- Détection de fraude ---
FRAUD_MAX_CLICKS_PER_IP_PER_MINUTE=10
FRAUD_MAX_CLICKS_PER_IP_PER_HOUR=50
FRAUD_CLICK_VELOCITY_THRESHOLD_MS=200
FRAUD_BLOCK_DURATION_MINUTES=60
FRAUD_AUTO_BLOCK_ENABLED=true

# --- Optimiseur ROI ---
ROI_MIN_COST_THRESHOLD=5.0
ROI_TARGET_CPA=15.0
ROI_MAX_BID_ADJUSTMENT_PCT=50
ROI_MIN_BID_ADJUSTMENT_PCT=-30
ROI_CHECK_INTERVAL_MINUTES=5
ROI_CONVERSION_WINDOW_DAYS=7

# --- Calendrier ---
CALENDAR_DEFAULT_TIMEZONE=Europe/Paris
CALENDAR_MAX_CONCURRENT_CAMPAIGNS=5

# --- Logs ---
LOG_LEVEL=info
LOG_FILE=./logs/app.log
